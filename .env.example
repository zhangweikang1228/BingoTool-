# ===========================================
# BingoTool 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填写实际值

# ===========================================
# 管理员配置（生产环境必须设置！）
# ===========================================
# 管理员邮箱
ADMIN_EMAIL=admin@yourdomain.com
# 密码哈希（PBKDF2-SHA512）和盐值
ADMIN_PASSWORD_HASH=你的100位十六进制哈希值
ADMIN_PASSWORD_SALT=你的32位十六进制盐值

# ===========================================
# 数据库配置（Neon PostgreSQL）
# ===========================================
# 从 Neon 控制台获取连接字符串
DATABASE_URL=postgresql://username:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ===========================================
# AI Gateway 配置
# ===========================================
OPENCLAW_TOKEN=your_openclaw_gateway_token

# ===========================================
# GitHub OAuth（可选）
# ===========================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ===========================================
# 微信登录（可选）
# ===========================================
WX_APP_ID=your_wx_app_id
WX_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# ===========================================
# NextAuth/应用配置
# ===========================================
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# 开发环境
# ===========================================
NODE_ENV=development
